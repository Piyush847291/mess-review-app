generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./mess.db" 
}

// 1. Mess Table (Har mess ki detail)
model Mess {
  id          String      @id @default(cuid())
  name        String      
  type        String      
  
  reviews     Review[]    
  complaints  Complaint[] 
}

// 2. Review Table
model Review {
  id        String   @id @default(cuid())
  rating    Int      
  comment   String?
  photoUrl  String?
  helpfulCount Int      @default(0)
  ownerReply   String?  // NEW: Optional field for the mess owner's response
  createdAt DateTime @default(now())
  
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
}

// 3. Complaint Table
model Complaint {
  id        String   @id @default(cuid())
  title     String   
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())
  
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
}